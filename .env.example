# Copy to .env and edit before `docker compose up`.

# Public address behind the nginx TLS proxy — used for the invite links the
# server prints on startup. Must be wss:// (not ws://) since nginx terminates TLS.
PUBLIC_URL=wss://poker.intensa.dev

# Invite-only seating. Bots connect to wss://poker.intensa.dev/?invite=<this>.
# Leave this line out entirely to auto-generate a random token (printed in logs),
# or set OPEN=1 (and remove INVITE) to let anyone take a seat.
INVITE=change-me-to-a-secret

# Tournament mode: escalating blinds every BLIND_LEVEL_HANDS hands.
# Comment out for a plain cash table.
TOURNAMENT=1

# Table tuning — defaults shown, uncomment to override.
# SMALL_BLIND=50
# BIG_BLIND=100
# BUY_IN=10000
# TURN_TIMEOUT_MS=30000
# MAX_HANDS=0
# BLIND_LEVEL_HANDS=20
